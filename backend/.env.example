# ===== SRITP Backend Environment =====
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# Server
PORT=5000
NODE_ENV=development

# Frontend origin(s) allowed by CORS (comma-separated, no trailing slash).
# Used for both REST and Socket.io. In production include your Vercel URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://sritp.vercel.app

# Used to build links inside emails (no trailing slash).
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/SRITP?retryWrites=true&w=majority

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_RESET_SECRET=replace_me

# Gmail (App Password, not your normal password)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password

# Cloudinary (file storage) — from https://cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
